<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Excel Shogbola — TPM & Full-Stack Developer</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=JetBrains+Mono:wght@300;400;500;700&family=Fraunces:ital,wght@0,300;0,700;1,300&display=swap" rel="stylesheet" />
  <style>
    :root {
      --bg:        #08090A;
      --bg2:       #101214;
      --bg3:       #161A1D;
      --border:    #1F2427;
      --amber:     #F5A623;
      --amber-dim: #b37b14;
      --green:     #00E887;
      --red:       #FF4759;
      --text:      #E8E8E8;
      --muted:     #6A7280;
      --card:      #111417;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'JetBrains Mono', monospace;
      overflow-x: hidden;
      cursor: none;
    }

    /* ── CUSTOM CURSOR ── */
    #cursor {
      position: fixed; width: 12px; height: 12px;
      background: var(--amber); border-radius: 50%;
      pointer-events: none; z-index: 9999;
      transform: translate(-50%, -50%);
      transition: transform .1s, background .2s;
      mix-blend-mode: difference;
    }
    #cursor-ring {
      position: fixed; width: 36px; height: 36px;
      border: 1px solid var(--amber);
      border-radius: 50%; pointer-events: none; z-index: 9998;
      transform: translate(-50%, -50%);
      transition: transform .18s ease, width .2s, height .2s, opacity .2s;
      opacity: .5;
    }

    /* ── GRID BACKGROUND ── */
    body::before {
      content: '';
      position: fixed; inset: 0;
      background-image:
        linear-gradient(rgba(245,166,35,.04) 1px, transparent 1px),
        linear-gradient(90deg, rgba(245,166,35,.04) 1px, transparent 1px);
      background-size: 48px 48px;
      z-index: 0; pointer-events: none;
    }

    /* ── NOISE GRAIN ── */
    body::after {
      content: '';
      position: fixed; inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.03'/%3E%3C/svg%3E");
      z-index: 0; pointer-events: none; opacity: .4;
    }

    /* ── LAYOUT ── */
    .container {
      position: relative; z-index: 1;
      max-width: 1100px; margin: 0 auto; padding: 0 2rem;
    }

    /* ── NAV ── */
    nav {
      position: fixed; top: 0; left: 0; right: 0;
      z-index: 100; padding: 1.2rem 2rem;
      display: flex; justify-content: space-between; align-items: center;
      background: rgba(8,9,10,.85);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .nav-logo {
      font-family: 'Syne', sans-serif;
      font-weight: 800; font-size: 1.1rem;
      color: var(--amber); letter-spacing: -.02em;
    }
    .nav-logo span { color: var(--green); }
    .nav-links {
      display: flex; gap: 2rem; list-style: none;
    }
    .nav-links a {
      color: var(--muted); text-decoration: none;
      font-size: .75rem; letter-spacing: .12em; text-transform: uppercase;
      transition: color .2s;
    }
    .nav-links a:hover { color: var(--amber); }
    .nav-status {
      display: flex; align-items: center; gap: .5rem;
      font-size: .7rem; color: var(--green);
    }
    .pulse { width: 7px; height: 7px; background: var(--green);
      border-radius: 50%; animation: pulse 1.8s ease infinite; }
    @keyframes pulse {
      0%,100% { box-shadow: 0 0 0 0 rgba(0,232,135,.5); }
      50%      { box-shadow: 0 0 0 6px rgba(0,232,135,0); }
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh; display: flex; flex-direction: column;
      justify-content: flex-end; padding: 8rem 0 5rem;
    }
    .hero-kicker {
      font-size: .72rem; color: var(--amber); letter-spacing: .2em;
      text-transform: uppercase; margin-bottom: 1.2rem;
      opacity: 0; animation: fadeUp .6s .3s forwards;
    }
    .hero-name {
      font-family: 'Syne', sans-serif;
      font-size: clamp(3.5rem, 9vw, 8rem);
      font-weight: 800; line-height: .95;
      letter-spacing: -.04em; color: var(--text);
      opacity: 0; animation: fadeUp .7s .5s forwards;
    }
    .hero-name em {
      font-family: 'Fraunces', serif;
      font-style: italic; color: var(--amber);
    }
    .hero-sub {
      margin-top: 1.8rem; max-width: 520px;
      font-size: .85rem; line-height: 1.8; color: var(--muted);
      opacity: 0; animation: fadeUp .7s .7s forwards;
    }
    .hero-sub strong { color: var(--text); font-weight: 500; }
    .hero-tags {
      display: flex; flex-wrap: wrap; gap: .6rem; margin-top: 2rem;
      opacity: 0; animation: fadeUp .7s .9s forwards;
    }
    .tag {
      border: 1px solid var(--border); padding: .3rem .75rem;
      font-size: .68rem; letter-spacing: .1em; text-transform: uppercase;
      color: var(--muted); border-radius: 2px; transition: all .2s;
    }
    .tag:hover { border-color: var(--amber); color: var(--amber); }
    .tag.green { border-color: rgba(0,232,135,.3); color: var(--green); }

    .hero-scroll {
      position: absolute; bottom: 2.5rem; left: 50%;
      transform: translateX(-50%);
      display: flex; flex-direction: column; align-items: center;
      gap: .4rem; color: var(--muted); font-size: .65rem;
      letter-spacing: .15em; text-transform: uppercase;
      animation: fadeIn 1s 1.5s both;
    }
    .scroll-line {
      width: 1px; height: 40px; background: var(--border);
      position: relative; overflow: hidden;
    }
    .scroll-line::after {
      content: ''; position: absolute; top: -100%;
      left: 0; width: 100%; height: 100%;
      background: var(--amber);
      animation: scrollDown 1.8s ease infinite;
    }
    @keyframes scrollDown { 0% { top: -100%; } 100% { top: 200%; } }
    @keyframes fadeUp { from { opacity:0; transform:translateY(20px); } to { opacity:1; transform:translateY(0); } }
    @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }

    /* ── SECTION LABELS ── */
    .section { padding: 6rem 0; }
    .section-label {
      display: flex; align-items: center; gap: 1rem;
      margin-bottom: 3rem;
    }
    .section-label .num {
      font-size: .68rem; color: var(--amber); letter-spacing: .2em;
      font-weight: 700;
    }
    .section-label h2 {
      font-family: 'Syne', sans-serif;
      font-size: 1.8rem; font-weight: 800;
      letter-spacing: -.03em; color: var(--text);
    }
    .section-label::after {
      content: ''; flex: 1; height: 1px; background: var(--border);
    }

    /* ── SKILLS GRID ── */
    .skills-categories {
      display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 2.5rem;
    }
    .cat-btn {
      padding: .4rem 1rem; font-size: .7rem; letter-spacing: .1em;
      text-transform: uppercase; background: transparent;
      border: 1px solid var(--border); color: var(--muted);
      cursor: none; transition: all .2s; border-radius: 2px;
      font-family: 'JetBrains Mono', monospace;
    }
    .cat-btn:hover, .cat-btn.active {
      background: var(--amber); border-color: var(--amber);
      color: var(--bg);
    }

    .skills-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1px; background: var(--border);
      border: 1px solid var(--border);
    }
    .skill-card {
      background: var(--card); padding: 1.4rem 1.6rem;
      transition: background .2s;
      display: none;
    }
    .skill-card.visible { display: block; }
    .skill-card:hover { background: var(--bg3); }
    .skill-header {
      display: flex; justify-content: space-between;
      align-items: center; margin-bottom: .9rem;
    }
    .skill-name {
      font-size: .82rem; font-weight: 500; color: var(--text);
      letter-spacing: .02em;
    }
    .skill-level {
      font-size: .65rem; color: var(--muted); letter-spacing: .1em;
    }
    .skill-bar {
      height: 2px; background: var(--border); border-radius: 1px;
      overflow: hidden;
    }
    .skill-fill {
      height: 100%; background: var(--amber);
      border-radius: 1px; width: 0;
      transition: width 1.2s cubic-bezier(.4,0,.2,1);
    }
    .skill-fill.green { background: var(--green); }
    .skill-fill.red   { background: var(--red);   }

    /* ── PROJECTS ── */
    .projects-grid {
      display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: 1.2rem;
    }
    .project-card {
      border: 1px solid var(--border); padding: 1.8rem;
      background: var(--card); position: relative;
      transition: border-color .25s, transform .25s;
      overflow: hidden;
    }
    .project-card::before {
      content: ''; position: absolute; top: 0; left: 0;
      width: 3px; height: 0; background: var(--amber);
      transition: height .4s cubic-bezier(.4,0,.2,1);
    }
    .project-card:hover::before { height: 100%; }
    .project-card:hover { border-color: rgba(245,166,35,.3); transform: translateY(-2px); }
    .project-card.featured::before { background: var(--green); }
    .project-card.featured:hover { border-color: rgba(0,232,135,.3); }

    .project-icon {
      font-size: 1.4rem; margin-bottom: 1rem;
    }
    .project-title {
      font-family: 'Syne', sans-serif;
      font-size: 1.05rem; font-weight: 700;
      color: var(--text); margin-bottom: .5rem;
      letter-spacing: -.02em;
    }
    .project-desc {
      font-size: .75rem; color: var(--muted); line-height: 1.7;
      margin-bottom: 1.2rem;
    }
    .project-stack {
      display: flex; flex-wrap: wrap; gap: .4rem;
    }
    .stack-tag {
      font-size: .62rem; padding: .2rem .5rem;
      background: var(--bg3); border: 1px solid var(--border);
      color: var(--muted); border-radius: 2px;
    }
    .project-badge {
      position: absolute; top: 1.2rem; right: 1.2rem;
      font-size: .6rem; padding: .2rem .5rem;
      background: rgba(0,232,135,.12); color: var(--green);
      border: 1px solid rgba(0,232,135,.3); border-radius: 2px;
      letter-spacing: .1em; text-transform: uppercase;
    }

    /* ── METHODOLOGY ── */
    .method-grid {
      display: grid; grid-template-columns: 1fr 1fr;
      gap: 1px; background: var(--border); border: 1px solid var(--border);
    }
    .method-cell {
      background: var(--card); padding: 2rem;
    }
    .method-num {
      font-size: .65rem; color: var(--amber);
      letter-spacing: .15em; margin-bottom: .8rem;
    }
    .method-title {
      font-family: 'Syne', sans-serif; font-size: 1.1rem;
      font-weight: 700; color: var(--text); margin-bottom: .6rem;
    }
    .method-desc {
      font-size: .75rem; color: var(--muted); line-height: 1.8;
    }
    .method-desc strong { color: var(--amber); font-weight: 500; }

    /* ── DOMAINS ── */
    .domains-list {
      display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem;
    }
    .domain-item {
      border: 1px solid var(--border); padding: 1.5rem;
      background: var(--card); display: flex; flex-direction: column;
      gap: .6rem; transition: border-color .2s;
    }
    .domain-item:hover { border-color: var(--amber); }
    .domain-icon { font-size: 1.3rem; }
    .domain-name {
      font-family: 'Syne', sans-serif; font-size: .9rem;
      font-weight: 700; color: var(--text);
    }
    .domain-desc { font-size: .72rem; color: var(--muted); line-height: 1.7; }

    /* ── CONTACT / FOOTER ── */
    .contact-section {
      border-top: 1px solid var(--border); padding: 5rem 0 4rem;
      display: flex; justify-content: space-between; align-items: flex-end;
      flex-wrap: wrap; gap: 2rem;
    }
    .contact-heading {
      font-family: 'Syne', sans-serif; font-size: clamp(2rem, 5vw, 4rem);
      font-weight: 800; letter-spacing: -.03em; color: var(--text);
    }
    .contact-heading em { font-family: 'Fraunces', serif; color: var(--amber); font-style: italic; }
    .contact-details { text-align: right; }
    .contact-line {
      font-size: .78rem; color: var(--muted); margin-bottom: .4rem;
    }
    .contact-line strong { color: var(--text); font-weight: 400; }
    .footer-bar {
      border-top: 1px solid var(--border); padding: 1.2rem 0;
      display: flex; justify-content: space-between; align-items: center;
    }
    .footer-copy { font-size: .65rem; color: var(--muted); letter-spacing: .1em; }
    .footer-credit { font-size: .65rem; color: var(--muted); }
    .footer-credit span { color: var(--amber); }

    /* ── TERMINAL TICKER ── */
    .ticker {
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
      padding: .7rem 0; overflow: hidden;
      background: var(--bg2); position: relative;
    }
    .ticker-inner {
      display: flex; gap: 3rem;
      animation: ticker 30s linear infinite;
      white-space: nowrap;
    }
    .ticker-item {
      font-size: .68rem; color: var(--muted); letter-spacing: .1em;
      text-transform: uppercase; flex-shrink: 0;
    }
    .ticker-item span { color: var(--amber); margin-right: .5rem; }
    @keyframes ticker { from { transform: translateX(0); } to { transform: translateX(-50%); } }

    /* ── RESPONSIVE ── */
    @media (max-width: 768px) {
      .method-grid { grid-template-columns: 1fr; }
      .domains-list { grid-template-columns: 1fr 1fr; }
      .contact-details { text-align: left; }
      .hero-name { font-size: clamp(2.8rem, 12vw, 5rem); }
      .nav-links { display: none; }
    }
    @media (max-width: 480px) {
      .domains-list { grid-template-columns: 1fr; }
    }

    /* ── SCROLL REVEAL ── */
    .reveal {
      opacity: 0; transform: translateY(24px);
      transition: opacity .7s ease, transform .7s ease;
    }
    .reveal.in { opacity: 1; transform: translateY(0); }
  </style>
</head>
